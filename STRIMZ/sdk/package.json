{
  "name": "@strimz/sdk",
  "version": "1.0.0",
  "description": "Accept crypto payments with one-time and recurring subscription support",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./server": {
      "import": "./dist/server.js",
      "require": "./dist/server.cjs",
      "types": "./dist/server.d.ts"
    },
    "./react": {
      "import": "./dist/react.js",
      "require": "./dist/react.cjs",
      "types": "./dist/react.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "tsc && vite build",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "strimz",
    "crypto",
    "payment",
    "payment-gateway",
    "usdc",
    "usdt",
    "subscription",
    "recurring-payments",
    "blockchain",
    "web3",
    "stablecoin",
    "checkout",
    "hosted-checkout"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/strimz-headquarters/strimz-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/strimz-headquarters/strimz-sdk/issues"
  },
  "homepage": "https://strimz-subscription.vercel.app/docs",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.5",
    "zod": "^3.22.4"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/react": "^14.1.2",
    "@types/node": "^20.10.6",
    "@types/react": "^18.2.46",
    "@types/react-dom": "^18.2.18",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.10",
    "vite-plugin-dts": "^3.7.0",
    "vitest": "^1.1.1"
  }
}
